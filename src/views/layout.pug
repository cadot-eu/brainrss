doctype html
html(lang="fr")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= title || "BrainRSS"
    link(rel="stylesheet" href="/css/style.css")
    link(rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect fill='%23FF6B35' width='100' height='100'/><circle cx='30' cy='30' r='8' fill='white'/><path d='M 20 50 Q 50 40 80 50' stroke='white' stroke-width='4' fill='none'/><path d='M 20 65 Q 50 55 80 65' stroke='white' stroke-width='4' fill='none'/></svg>")
  body
    .container
      header.header
        .header-content
          h1.logo
            a(href="/") 📰 BrainRSS
          nav.nav-main
            ul
              li
                a(href="/") Accueil
              li
                a(href="/feeds") Flux
              li
                a(href="/unread") Non lus
                if unreadCount > 0
                  span.badge= unreadCount
              li
                a(href="/filters") Filtres
              li
                a(href="/saved") Sauvegardés
        #refresh-bar.refresh-bar(style="display:none")
          .refresh-bar-inner
            span.refresh-bar-icon 🔄
            span#refresh-bar-text Rafraîchissement en cours...
            span#refresh-bar-progress
            #refresh-bar-details.refresh-bar-details

      main.main-content
        #articleSearch.search-bar(style="display:none")
          input#searchInput(type="text" placeholder="Rechercher dans les articles..." autocomplete="off")
          label.search-whole-word
            input#searchWholeWord(type="checkbox")
            | Mot entier
          span#searchCount.search-count
        block content

      footer.footer
        p © 2024 BrainRSS - Un lecteur RSS moderne
        p
          a(href="https://github.com/WCY-dt/BrainRSS" target="_blank") Basé sur BrainRSS

    script(src="/js/main.js?v=20260701")
    block scripts
